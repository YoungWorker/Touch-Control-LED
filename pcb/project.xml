  <general>
    <title>Touch Control LED - Complete Design</title>
    <description>ESP8266-based touch-controlled smart light with adjustable color temperature. This project demonstrates embedded systems design with microcontrollers, sensors, and RGB LED control.</description>
    <author>YoungWorker</author>
    <date>2026-06-13</date>
    <version>1.0</version>
    <license>MIT License</license>
  </general>

  <schematic>
    <file path="Touch_Control_LED.kicad_sch"/>
    <version>KiCad 6.0+</version>
    <last_modified>2026-06-13</last_modified>
  </schematic>

  <pcb>
    <file path="Touch_Control_LED.kicad_pcb"/>
    <version>KiCad 6.0+</version>
    <board_dimensions>
      <width_mm>48</width_mm>
      <height_mm>93</height_mm>
      <thickness_mm>1.6</thickness_mm>
    </board_dimensions>
    <layers>2</layers>
    <copper_weight>35um</copper_weight>
    <last_modified>2026-06-13</last_modified>
  </pcb>

  <component_list>
    <component>
      <reference>J1</reference>
      <name>USB Micro-B Connector</name>
      <value>USB_Micro-B_Amphenol</value>
      <footprint>Connector_USB:USB_Micro-B_Amphenol_10118194</footprint>
      <description>Micro USB connector for 5V power input</description>
      <pins>VBUS GND</pins>
      <supplier>Generic</supplier>
      <cost>2-5 CNY</cost>
    </component>

    <component>
      <reference>U1</reference>
      <name>ESP8266 D1 Mini Development Board</name>
      <value>ESP8266</value>
      <footprint>Module:ESP8266_D1_Mini</footprint>
      <description>WiFi-enabled microcontroller with 11 GPIO pins, 1MB flash memory</description>
      <pins>5V GND D1 D2 D3 D4 D5 TX RX</pins>
      <voltage>3.3V logic, 5V USB input</voltage>
      <frequency>80 MHz</frequency>
      <memory>1MB Flash, 160KB RAM</memory>
      <supplier>Taobao, AliExpress</supplier>
      <cost>25-35 CNY</cost>
    </component>

    <component>
      <reference>U2</reference>
      <name>TTP223 Capacitive Touch Sensor Module</name>
      <value>TTP223</value>
      <footprint>Sensor:TTP223</footprint>
      <description>Single-channel capacitive touch pad sensor with automatic power-down</description>
      <pins>VCC GND OUT</pins>
      <voltage>2.4-5.5V</voltage>
      <output>HIGH when touched, LOW when released</output>
      <response_time>60ms typical</response_time>
      <supplier>Taobao, AliExpress</supplier>
      <cost>8-12 CNY</cost>
    </component>

    <component>
      <reference>R1</reference>
      <name>Resistor 220 Ohm - Cool White LED current limiting</name>
      <value>220Ω</value>
      <footprint>Resistor_SMD:R_1206</footprint>
      <tolerance>5%</tolerance>
      <power_rating>0.25W</power_rating>
      <supplier>Generic, Taobao</supplier>
      <cost>0.05-0.1 CNY</cost>
    </component>

    <component>
      <reference>R2</reference>
      <name>Resistor 220 Ohm - Warm White LED current limiting</name>
      <value>220Ω</value>
      <footprint>Resistor_SMD:R_1206</footprint>
      <tolerance>5%</tolerance>
      <power_rating>0.25W</power_rating>
      <supplier>Generic, Taobao</supplier>
      <cost>0.05-0.1 CNY</cost>
    </component>

    <component>
      <reference>R3</reference>
      <name>Resistor 220 Ohm - Mix LED current limiting</name>
      <value>220Ω</value>
      <footprint>Resistor_SMD:R_1206</footprint>
      <tolerance>5%</tolerance>
      <power_rating>0.25W</power_rating>
      <supplier>Generic, Taobao</supplier>
      <cost>0.05-0.1 CNY</cost>
    </component>

    <component>
      <reference>LED1</reference>
      <name>LED - Cool White 5mm</name>
      <value>LED_CoolWhite</value>
      <footprint>LED_SMD:LED_1206</footprint>
      <color>White (6000-7000K)</color>
      <voltage>3.3V forward voltage typical</voltage>
      <current>20mA typical</current>
      <brightness>-5000mcd</brightness>
      <supplier>Taobao, AliExpress</supplier>
      <cost>0.5-1 CNY</cost>
    </component>

    <component>
      <reference>LED2</reference>
      <name>LED - Warm White 5mm</name>
      <value>LED_WarmWhite</value>
      <footprint>LED_SMD:LED_1206</footprint>
      <color>Warm White (2700-3000K)</color>
      <voltage>3.3V forward voltage typical</voltage>
      <current>20mA typical</current>
      <brightness>~5000mcd</brightness>
      <supplier>Taobao, AliExpress</supplier>
      <cost>0.5-1 CNY</cost>
    </component>

    <component>
      <reference>LED3</reference>
      <name>LED - Warm-Cool Mix 5mm</name>
      <value>LED_WarmCool</value>
      <footprint>LED_SMD:LED_1206</footprint>
      <color>Warm White (3000-4000K)</color>
      <voltage>3.3V forward voltage typical</voltage>
      <current>20mA typical</current>
      <brightness>~5000mcd</brightness>
      <supplier>Taobao, AliExpress</supplier>
      <cost>0.5-1 CNY</cost>
    </component>

    <component>
      <reference>C1</reference>
      <name>Capacitor - Power supply decoupling</name>
      <value>10µF/25V</value>
      <footprint>Capacitor_SMD:C_0805</footprint>
      <type>Ceramic/Electrolytic</type>
      <voltage>25V rated</voltage>
      <esr>~0.1Ω typical</esr>
      <supplier>Generic, Taobao</supplier>
      <cost>0.1-0.2 CNY</cost>
