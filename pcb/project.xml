  <electrical_parameters>
    <power_supply>
      <input_voltage>5V USB</input_voltage>
      <input_current_max>1A</input_current_max>
      <regulated_voltage>3.3V (from ESP8266 regulator)</regulated_voltage>
      <logic_voltage>3.3V</logic_voltage>
    </power_supply>
    <led_specifications>
      <led_voltage>3.3V typical forward voltage</led_voltage>
      <led_current>20mA per LED</led_current>
      <total_current_max>60mA (3 LEDs) + 80mA (MCU) = ~140mA</total_current_max>
      <pwm_frequency>1000Hz (configurable in firmware)</pwm_frequency>
      <pwm_resolution>8-bit (0-255)</pwm_resolution>
    </led_specifications>
    <gpio_specifications>
      <gpio_voltage>3.3V</gpio_voltage>
      <gpio_max_current>12mA per pin</gpio_max_current>
      <pull_up_internal>Yes (configurable)</pull_up_internal>
      <pull_down_internal>Yes (configurable)</pull_down_internal>
    </gpio_specifications>
  </electrical_parameters>

  <design_rules>
    <trace_width>
      <minimum>0.2mm</minimum>
      <typical>0.3mm</typical>
      <power>0.5mm</power>
      <ground>0.5mm</ground>
    </trace_width>
    <clearance>
      <trace_to_trace>0.2mm</trace_to_trace>
      <pad_to_pad>0.2mm</pad_to_pad>
      <trace_to_pad>0.2mm</trace_to_pad>
    </clearance>
    <via>
      <diameter_minimum>0.3mm</diameter_minimum>
      <diameter_typical>0.5mm</diameter_typical>
      <hole_diameter>0.2mm</hole_diameter>
    </via>
  </design_rules>

  <manufacturing_specs>
    <pcb_substrate>FR-4</pcb_substrate>
    <pcb_thickness>1.6mm</pcb_thickness>
    <copper_weight>35µm (1oz)</copper_weight>
    <layers>2 (Front and Back)</layers>
    <solder_mask>Green epoxy</solder_mask>
    <silk_screen>White</silk_screen>
    <surface_finish>HASL (Hot Air Solder Leveling)</surface_finish>
    <edge_connector>None</edge_connector>
    <fiducial_marks>2x (optional)</fiducial_marks>
    <production_panelization>Can be panelized with 2-3mm rails</production_panelization>
  </manufacturing_specs>

  <thermal_design>
    <ambient_temperature>0-40°C operating</ambient_temperature>
    <power_dissipation>
      <esp8266>~80mA @ 3.3V = 0.26W</esp8266>
      <resistors>Each resistor: 20mA² × 220Ω = 0.088W per resistor × 3 = 0.26W total</resistors>
      <leds>3 × 20mA × 3.3V = 0.2W total</leds>
      <total_estimated>~0.8W maximum</total_estimated>
    </power_dissipation>
    <thermal_considerations>
      <heat_generation>Low - passive cooling sufficient</heat_generation>
      <heatsink>Not required</heatsink>
      <air_circulation>Natural convection adequate</air_circulation>
    </thermal_considerations>
  </thermal_design>

